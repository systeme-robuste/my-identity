# My Identity — Local development environment variables
# Copy to .env and fill in real values. NEVER commit .env.
#
# This file is read by docker-compose.yml AND by the apps during dev mode.
# Production values are set as Cloudflare Workers Secrets (see scripts/bootstrap-cloudflare.sh).

# ---------- App-wide ----------
NODE_ENV=development
LOG_LEVEL=debug
APP_NAME="My Identity"
APP_VERSION=0.1.0

# ---------- Postgres (docker-compose) ----------
DATABASE_URL=postgresql://myidentity:myidentity_dev@localhost:5432/myidentity_dev
DATABASE_URL_UNPOOLED=postgresql://myidentity:myidentity_dev@localhost:5432/myidentity_dev

# ---------- Auth ----------
AUTH_SECRET=dev-only-do-not-use-in-prod-replace-with-32-bytes-from-openssl-rand
AUTH_SESSION_COOKIE_NAME=mi_session

# ---------- Email (Mailpit local) ----------
RESEND_API_KEY=local-mailpit-key
RESEND_FROM_EMAIL=hello@myidentity.local
RESEND_REPLY_TO=support@myidentity.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ---------- Stripe (test mode) ----------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_ID_PRO_YEARLY=price_replace_me
STRIPE_PRICE_ID_BUSINESS_MONTHLY=price_replace_me
STRIPE_PRICE_ID_BUSINESS_YEARLY=price_replace_me

# ---------- Mistral AI ----------
MISTRAL_API_KEY=replace_me
MISTRAL_MODEL=mistral-large-latest

# ---------- Cloudflare Turnstile ----------
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ---------- Cloudflare R2 (for direct uploads) ----------
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET_NAME=my-identity-media
R2_PUBLIC_BASE_URL=http://localhost:8080

# ---------- Renderer ----------
RENDERER_BASE_URL=http://localhost:8788
API_BASE_URL=http://localhost:8787

# ---------- Dashboard ----------
APP_BASE_URL=http://localhost:5173

# ---------- Sentry (optional) ----------
SENTRY_DSN=

# ---------- Misc ----------
ANALYTICS_SAMPLE_RATE=0.1
RATE_LIMIT_PER_MIN=600
