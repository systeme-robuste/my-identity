# =====================================================================
# My Identity — Environment variables (placeholders only)
# Copy to .env and fill in. NEVER commit a real .env file.
# =====================================================================

# --- App ---
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

# --- Database (Neon Postgres, serverless) ---
# Get from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/myidentity?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/myidentity?sslmode=require

# --- Cloudflare D1 (edge cache) ---
# wrangler d1 create my-identity-cache
D1_DATABASE_ID=00000000-0000-0000-0000-000000000000
D1_DATABASE_NAME=my-identity-cache

# --- Cloudflare KV (sessions, rate-limit, cache) ---
# wrangler kv namespace create SESSIONS
KV_NAMESPACE_ID_SESSIONS=00000000000000000000000000000000
# wrangler kv namespace create RATE_LIMIT
KV_NAMESPACE_ID_RATE_LIMIT=00000000000000000000000000000000
# wrangler kv namespace create RENDER_CACHE
KV_NAMESPACE_ID_RENDER_CACHE=00000000000000000000000000000000

# --- Cloudflare R2 (object storage: media, attachments) ---
R2_ACCOUNT_ID=00000000000000000000000000000000
R2_ACCESS_KEY_ID=00000000000000000000000000000000
R2_SECRET_ACCESS_KEY=00000000000000000000000000000000
R2_BUCKET_NAME=my-identity-media
R2_PUBLIC_BASE_URL=https://media.myidentity.app

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=REPLACE_WITH_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=no-reply@myidentity.app
RESEND_REPLY_TO=support@myidentity.app

# --- Stripe (billing) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_PRO_MONTHLY=REPLACE_WITH_PRO_MONTHLY_PRICE_ID
STRIPE_PRICE_PRO_YEARLY=REPLACE_WITH_PRO_YEARLY_PRICE_ID
STRIPE_PRICE_BUSINESS_MONTHLY=REPLACE_WITH_BUSINESS_MONTHLY_PRICE_ID
STRIPE_PRICE_BUSINESS_YEARLY=REPLACE_WITH_BUSINESS_YEARLY_PRICE_ID

# --- Mistral (AI workflows) ---
# https://console.mistral.ai
MISTRAL_API_KEY=REPLACE_WITH_YOUR_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-large-latest

# --- Cloudflare Turnstile (bot protection) ---
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Auth ---
AUTH_SESSION_COOKIE_NAME=mi_session
AUTH_SESSION_TTL_DAYS=30
AUTH_SECRET=change-me-32-bytes-of-random-base64=

# --- URLs ---
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8787
RENDERER_BASE_URL=http://localhost:8788
DASHBOARD_URL=http://localhost:5173
MARKETING_URL=http://localhost:5174
DOCS_URL=http://localhost:5175

# --- Feature flags ---
FEATURE_A_B_TESTING=false
FEATURE_AI_WORKFLOWS=false
FEATURE_ECOMMERCE=false
FEATURE_MEMBERSHIPS=false

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
