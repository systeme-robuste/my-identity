{
  "name": "@my-identity/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx watch src/node-server.ts",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "build:node": "echo 'no bundle needed, tsx runs .ts directly'",
    "render:bundle": "pnpm run build:node",
    "render:build": "pnpm run render:bundle",
    "start:node": "tsx src/node-server.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test:unit": "vitest run",
    "test": "vitest run",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "@my-identity/bindings": "workspace:*",
    "@my-identity/db": "workspace:*",
    "@my-identity/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "drizzle-orm": "^0.31.0",
    "hono": "^4.4.0",
    "@hono/zod-validator": "^0.2.0",
    "@neondatabase/serverless": "^0.9.0",
    "@cloudflare/workers-types": "^4.20240605.0",
    "resend": "^3.4.0",
    "stripe": "^15.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.60.0"
  }
}