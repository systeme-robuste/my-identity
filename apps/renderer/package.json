{
  "name": "@my-identity/renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx watch src/node-server.ts",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "build:node": "esbuild src/node-server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/node-server.mjs --packages=external",
    "render:bundle": "pnpm run build:node",
    "start:node": "node dist/node-server.mjs",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: renderer (no-op)'",
    "test:unit": "echo 'no tests yet'",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "@my-identity/bindings": "workspace:*",
    "@my-identity/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240605.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0"
  }
}
